# ============================================
# SERVER CONFIGURATION
# ============================================

# Port for the backend server
PORT=5000

# Environment: development | production
# In production, errors are generic and stack traces are hidden
NODE_ENV=development

# ============================================
# DATABASE CONFIGURATION
# ============================================

# MongoDB Connection String
# Development: mongodb://localhost:27017/saas_auth_platform
# Production: mongodb://username:password@localhost:27017/saas_auth_platform?authSource=admin
MONGODB_URI=mongodb://localhost:27017/saas_auth_platform

# ============================================
# REDIS CONFIGURATION
# ============================================

# Redis Host
REDIS_HOST=localhost

# Redis Port
REDIS_PORT=6379

# Redis Password (leave empty for development, set in production)
REDIS_PASSWORD=

# ============================================
# JWT CONFIGURATION
# ============================================

# JWT Access Token Secret
# CRITICAL: Generate a strong random secret for production!
# Generate with: openssl rand -base64 64
# Or: node -e "console.log(require('crypto').randomBytes(64).toString('base64'))"
JWT_ACCESS_SECRET=your-super-secret-access-key-change-this-in-production-min-32-chars

# JWT Refresh Token Secret
# CRITICAL: Generate a different strong random secret for production!
# Must be different from JWT_ACCESS_SECRET
JWT_REFRESH_SECRET=your-super-secret-refresh-key-change-this-in-production-min-32-chars

# JWT Token Expiry Times
# Access token: Short-lived (15 minutes recommended)
# Format: 15m, 1h, 1d, etc.
JWT_ACCESS_EXPIRY=15m

# Refresh token: Long-lived (7 days recommended)
# Format: 7d, 30d, etc.
JWT_REFRESH_EXPIRY=7d

# ============================================
# PASSWORD SECURITY
# ============================================

# bcrypt Salt Rounds
# Higher = more secure but slower
# Recommended: 12 (production), 10 (development)
BCRYPT_ROUNDS=12

# Maximum failed login attempts before account lockout
MAX_LOGIN_ATTEMPTS=5

# Account lockout duration in milliseconds
# 900000 = 15 minutes
LOCKOUT_TIME=900000

# ============================================
# RATE LIMITING
# ============================================

# Rate limit time window in milliseconds
# 900000 = 15 minutes
RATE_LIMIT_WINDOW=900000

# Maximum requests per window (global)
RATE_LIMIT_MAX=100

# ============================================
# REQUEST VALIDATION (CLIENT API)
# ============================================

# Timestamp tolerance in milliseconds
# Requests outside this window are rejected (prevents replay attacks)
# 30000 = 30 seconds
TIMESTAMP_TOLERANCE=30000

# Nonce Time-To-Live in seconds
# How long nonces are stored in Redis
# 60 = 1 minute
NONCE_TTL=60

# ============================================
# CORS CONFIGURATION
# ============================================

# Frontend URL for CORS
# Development: http://localhost:3000
# Production: https://yourdomain.com
FRONTEND_URL=http://localhost:3000

# ============================================
# OPTIONAL CONFIGURATION
# ============================================

# Session expiry in milliseconds (default: 24 hours)
# SESSION_EXPIRY=86400000

# Heartbeat interval in milliseconds (default: 30 seconds)
# HEARTBEAT_INTERVAL=30000

# Audit log retention in days (default: 90 days)
# AUDIT_LOG_RETENTION=90

# ============================================
# PRODUCTION CHECKLIST
# ============================================
# Before deploying to production:
# [ ] Change JWT_ACCESS_SECRET to a strong random value
# [ ] Change JWT_REFRESH_SECRET to a different strong random value
# [ ] Set NODE_ENV=production
# [ ] Enable MongoDB authentication
# [ ] Set Redis password
# [ ] Update FRONTEND_URL to your domain
# [ ] Use HTTPS (configure in reverse proxy)
# [ ] Set up firewall rules
# [ ] Configure automated backups
# [ ] Set up monitoring and alerts
# ============================================
